# SACCTC Backend - variables de entorno
# Copiar a .env y ajustar valores. NUNCA commitear .env con credenciales.

FLASK_ENV=development

# Claves (generar con: python -c "import secrets; print(secrets.token_hex(32))")
SECRET_KEY=cambiar-en-produccion
JWT_SECRET_KEY=cambiar-en-produccion

# PostgreSQL (sin IPs hardcodeadas: bug legacy corregido)
DATABASE_URL=postgresql://userud:password@localhost:5432/BDUDESTRO_NEW?client_encoding=utf8

# CORS: origenes del frontend separados por coma
CORS_ORIGINS=http://localhost:3000
